{
  "name": "preformat",
  "version": "1.0.0",
  "description": "Herramienta para preparar tu PC antes de formatear",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.tuapp.preformat",
    "productName": "PreFormat",
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "winreg": "^1.2.4",
    "fast-csv": "^4.3.6",
    "pdfkit": "^0.13.0",
    "archiver": "^6.0.1",
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "author": "Tu Nombre",
  "license": "MIT"
}
