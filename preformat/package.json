{
  "name": "preformat",
  "version": "1.0.0",
  "description": "Herramienta para preparar tu PC antes de formatear",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "node build-manual.js",
    "build:portable": "node build-manual.js"
  },
  "build": {
    "appId": "com.tuapp.preformat",
    "productName": "PreFormat",
    "asar": false,
    "win": {
      "target": "portable",
      "icon": "assets/icons/icon.ico",
      "sign": null
    },
    "portable": {
      "artifactName": "${productName}-${version}.exe"
    }
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "electron-store": "^8.1.0",
    "fast-csv": "^4.3.6",
    "js-yaml": "^4.1.1",
    "node-forge": "^1.3.1",
    "pdfkit": "^0.13.0",
    "vdf": "^0.0.2",
    "winreg": "^1.2.4"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "author": "Tu Nombre",
  "license": "MIT"
}
